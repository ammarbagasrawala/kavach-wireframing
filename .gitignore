# ── Next.js ──────────────────────────────────────────────────
.next/
out/
node_modules/
npm-debug.log*

# ── Python backends ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# ── SQLite databases (runtime state, not source) ─────────────
backends/**/*.db
*.db

# ── IDfy result files (runtime, can be large) ────────────────
backends/idfy-api/results/

# ── Environment secrets ──────────────────────────────────────
.env
.env.local
# Keep the example templates:
!.env.example
!backends/**/.env.example

# ── Misc ─────────────────────────────────────────────────────
.DS_Store
*.log
.cursor/
