# ── Next.js UI (wireframes) ──────────────────────────────────
# The origin of the IDfy backend (Port 8000) - Used for DigiLocker fetch
NEXT_PUBLIC_API_URL=http://localhost:8000

# The origin of the CKYCR Mock backend (Port 8001)
NEXT_PUBLIC_CKYCR_API_URL=http://localhost:8001

# The base URL of this Next.js app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── IDfy Backend (backends/idfy-api) ─────────────────────────
IDFY_ACCOUNT_ID="your_account_id"
IDFY_API_KEY="your_api_key"

# IDfy credentials for the 'data' payload
IDFY_KEY_ID="3e281012-449b-4305-be16-7999ed7c65c6"
IDFY_OU_ID="731b23f196a7"
IDFY_SECRET="YmY2YjQzZTJhYmM0NDliYmFkNTNmOWJlZTEyMzM2YWQ="

# Webhook configuration
# Set USE_NGROK=true to automatically tunnel port 8000 for IDfy callbacks
USE_NGROK="true"
NGROK_AUTHTOKEN="your_ngrok_token"
# If not using ngrok, set this to your public domain
# IDFY_WEBHOOK_BASE_URL="https://your-domain.ngrok-free.app"

# ── CKYCR Mock Backend (backends/ckycr-mock) ──────────────────
# SQLite Database URL
DATABASE_URL="sqlite:///./ckyc_mock.db"
KAVACH_DATABASE_URL="sqlite:///./kavach_app.db"

# Enable development routes (admin, etc.)
ENABLE_DEV_ROUTES="true"
