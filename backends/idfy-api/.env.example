# IDfy credentials
IDFY_ACCOUNT_ID="your_account_id_here"
IDFY_API_KEY="your_api_key_here"

# Webhook configuration
# OPTION A: Use IDfy's online webhook tool (e.g., https://webhooks.idfy.tech/...)
# If you provide this, the app will send webhooks to this URL instead of your local machine.
IDFY_WEBHOOK_URL="https://webhooks.idfy.tech/your-unique-uuid-here"

# OPTION B: Ngrok Auto-tunneling to your local machine (Disable this by setting USE_NGROK=false)
USE_NGROK="false"
NGROK_AUTHTOKEN="your_ngrok_auth_token_here"
