# CKYCR mock DB (SQLite path or postgres URL)
# DATABASE_URL=sqlite:////absolute/path/to/ckyc_mock.db

# Kavach metadata DB (separate file — no raw PII)
# KAVACH_DATABASE_URL=sqlite:////absolute/path/to/kavach_app.db

# Optional Redis for DigiLocker OAuth state + IDfy webhook payload cache
# REDIS_URL=redis://127.0.0.1:6379/0

# DigiLocker OAuth (digilocker-auth python package lives at kavach-ab-digilocker-auth-module/modules/digilocker-auth/python)
DIGILOCKER_MOCK=true
DIGILOCKER_REDIRECT_URI=http://127.0.0.1:8000/auth/digilocker/callback
DIGILOCKER_FRONTEND_REDIRECT=http://localhost:3000/bank

# IDfy DigiLocker fetch (ind_digilocker_fetch_documents) — required for /integrations/idfy/*
# ENABLE_IDFY_DIGILOCKER must be true or API returns 503
# ENABLE_IDFY_DIGILOCKER=true
# IDFY_ACCOUNT_ID=
# IDFY_API_KEY=
# IDFY_KEY_ID=
# IDFY_OU_ID=
# IDFY_SECRET=
# Optional: full webhook URL (else built from IDFY_WEBHOOK_BASE_URL)
# IDFY_WEBHOOK_URL=
# Public HTTPS base for IDfy redirect + webhook callbacks (optional if USE_NGROK=true — runtime sets KAVACH_IDFY_PUBLIC_BASE).
# If ngrok fails with ERR_NGROK_334 (reserved domain already online), set this to that HTTPS URL and restart, or stop the other tunnel.
# IDFY_WEBHOOK_BASE_URL=https://your-subdomain.ngrok-free.dev
# Auto-ngrok (same pattern as DIGILOCKER_PAN_ADHAAR_FLOW; uses NGROK_AUTHTOKEN from that folder's .env when merged)
# USE_NGROK=true
# NGROK_AUTHTOKEN=
# NGROK_LOCAL_PORT=8000
# Optional: reserved hostname only (e.g. xxxx.ngrok-free.dev) for pyngrok connect
# NGROK_DOMAIN=
# Where the FastAPI /integrations/idfy/return handler redirects the browser after IDfy (Next.js dev server)
# KAVACH_WIREFRAME_ORIGIN=http://localhost:3000
